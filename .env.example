# Resend (transactional email for the contact form).
# Without RESEND_API_KEY the API route falls back to console.log so dev
# never blocks on missing config.
RESEND_API_KEY=

# Where contact form submissions get delivered.
# Falls back to CONTACT_EMAIL in lib/site.ts if unset.
CONTACT_TO_EMAIL=

# From address shown on outbound emails.
# 'onboarding@resend.dev' works immediately with any Resend account, no DNS
# setup required. Once cswebstudio.tech is verified in Resend, switch to
# something like 'CS Web Studio <hello@cswebstudio.tech>'.
CONTACT_FROM_EMAIL=
